# Tests are local-only and not part of the production review surface.
# Ignore everything under src/test/, then allowlist only what the
# shadow JAR build needs: PvPLeaderboardPluginTest is the Main-Class
# named in build.gradle's shadowJar manifest and must stay tracked.
src/test/**
!src/test/
!src/test/java/
!src/test/java/com/
!src/test/java/com/pvp/
!src/test/java/com/pvp/leaderboard/
!src/test/java/com/pvp/leaderboard/PvPLeaderboardPluginTest.java

# Internal handoffs / progress trackers / architecture deep-dives —
# kept on disk for local reference but not part of the GitHub review
# surface. README.md at the repo root remains tracked.
docs/